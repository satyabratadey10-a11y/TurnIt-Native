<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_bottom_sheet"
    android:paddingBottom="32dp">
    <View android:layout_width="40dp" android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp" android:layout_marginBottom="4dp"
        android:background="#44C084FC" />
    <TextView android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/select_model"
        android:textColor="@color/color_aurora"
        android:textSize="15sp" android:textStyle="bold"
        android:paddingStart="20dp" android:paddingTop="12dp"
        android:paddingBottom="8dp" />
    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="#22C084FC" android:layout_marginBottom="4dp" />
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_models"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />
</LinearLayout>
