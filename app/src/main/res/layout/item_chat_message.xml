<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="4dp">
    <LinearLayout android:id="@+id/container_user"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:layout_marginStart="48dp"
        android:orientation="vertical"
        android:visibility="gone">
        <TextView android:id="@+id/tv_user_message"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/glass_bubble_user"
            android:textColor="#FFFFFFFF"
            android:textSize="14sp"
            android:paddingStart="14dp" android:paddingEnd="14dp"
            android:paddingTop="10dp" android:paddingBottom="10dp"
            android:lineSpacingMultiplier="1.3" />
    </LinearLayout>
    <LinearLayout android:id="@+id/container_ai"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="start"
        android:layout_marginEnd="48dp"
        android:orientation="vertical"
        android:visibility="gone">
        <TextView android:id="@+id/tv_ai_message"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/glass_bubble_ai"
            android:textColor="#FFE0E8FF"
            android:textSize="14sp"
            android:paddingStart="14dp" android:paddingEnd="14dp"
            android:paddingTop="10dp" android:paddingBottom="10dp"
            android:lineSpacingMultiplier="1.3" />
    </LinearLayout>
</FrameLayout>
