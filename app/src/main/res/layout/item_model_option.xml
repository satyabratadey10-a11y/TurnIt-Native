<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="16dp"
    android:gravity="center_vertical"
    android:background="?attr/selectableItemBackground">
    <LinearLayout android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">
        <TextView android:id="@+id/tv_model_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFFFF"
            android:textSize="15sp" android:textStyle="bold" />
        <TextView android:id="@+id/tv_model_desc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FF886699"
            android:textSize="12sp" android:layout_marginTop="2dp" />
    </LinearLayout>
    <ImageView android:id="@+id/iv_model_check"
        android:layout_width="20dp" android:layout_height="20dp"
        android:src="@drawable/ic_check"
        android:visibility="invisible" />
</LinearLayout>
