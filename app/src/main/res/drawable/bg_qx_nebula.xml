<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Base Void -->
    <item><shape><solid android:color="#010409" /></shape></item>

    <!-- Nebula Purple (Increased visibility) -->
    <item android:top="-100dp" android:right="-50dp">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="600dp"
                android:startColor="#CC1A0B2E" 
                android:endColor="#001A0B2E" />
        </shape>
    </item>

    <!-- Aurora Teal (Increased visibility) -->
    <item android:bottom="-50dp" android:left="-50dp">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="500dp"
                android:startColor="#9900D1FF"
                android:endColor="#0000D1FF" />
        </shape>
    </item>
</layer-list>
